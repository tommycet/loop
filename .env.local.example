# --- Loop — local development environment ---
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; .env.local.example is the template.

# --- App mode ---
DEMO_MODE=false

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers ---
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant
GROQ_PLANNER_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_MODEL=qwen/qwen-2.5-72b-instruct

# --- Inngest ---
# Local dev: set INNGEST_DEV=1 so the SDK uses the inngest-cli dev server
# on http://localhost:8288. Do NOT set INNGEST_EVENT_KEY locally — the dev
# server is unauthenticated.
#
# Vercel (production): unset INNGEST_DEV, set INNGEST_EVENT_KEY and
# INNGEST_SIGNING_KEY to the values from https://app.inngest.com
#
INNGEST_DEV=1
INNGEST_API_URL=http://localhost:8288
# INNGEST_EVENT_KEY=signkey-prod-***           # production only
# INNGEST_SIGNING_KEY=signkey-prod-***         # production only

# --- Telegram (the only channel enabled for this walkthrough) ---
# Create a bot: message @BotFather on Telegram → /newbot → copy the token
# Get your chat_id: send your bot a message, then visit
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# After starting the server, register the webhook with secret token:
#   curl "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/setWebhook?url=${LOOP_PUBLIC_URL}/api/inbound/telegram&secret_token=${TELEGRAM_WEBHOOK_SECRET}"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DIGEST_CHAT_ID=

# --- Public URL ---
# Where the cloudflared/ngrok tunnel exposes the local server.
# Telegram's webhook will POST to this URL.
LOOP_PUBLIC_URL=

# --- Optional (legacy channels) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# WAPPFLY_API_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_WEBHOOK_SECRET=
# META_APP_SECRET=
# META_VERIFY_TOKEN=
# META_PHONE_NUMBER_ID=
# META_WHATSAPP_TOKEN=
# META_DIGEST_TO=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_SIGNING_SECRET=
